# AWS authentication
# Recommended: use AWS_PROFILE and keep the static key fields empty.
# Alternative: leave AWS_PROFILE empty and fill AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Infrastructure
# AWS_CLUSTER_NAME is used in tags and generated metadata.
AWS_CLUSTER_NAME=productive-k3s-aws
# Default size chosen for a realistic Productive K3S single-node evaluation.
AWS_INSTANCE_TYPE=t3a.xlarge
AWS_ROOT_VOLUME_SIZE_GB=80
# Existing EC2 key pair name in AWS.
AWS_KEY_PAIR_NAME=your-existing-keypair
# Absolute local path to the matching private key file.
AWS_SSH_KEY_PATH=/absolute/path/to/your-key.pem
AWS_SSH_USER=ubuntu
AWS_SSH_PORT=22

# Networking
# Leave VPC/SUBNET empty to use the default VPC path.
AWS_VPC_ID=
AWS_SUBNET_ID=
# Recommended for a first test: restrict these to your public IP with /32.
AWS_SSH_ALLOWED_CIDR=0.0.0.0/0
AWS_HTTP_ALLOWED_CIDR=0.0.0.0/0
AWS_API_ALLOWED_CIDR=0.0.0.0/0

# Optional overrides
# Leave AWS_AMI_ID empty unless you want to force a specific Ubuntu image.
AWS_AMI_ID=
AWS_BASE_DOMAIN=k3s.lab.internal
AWS_RANCHER_HOST=rancher.k3s.lab.internal
AWS_REGISTRY_HOST=registry.k3s.lab.internal
AWS_REMOTE_DIR=/home/ubuntu/productive-k3s-core

# productive-k3s bundle source
# remote: download a published productive-k3s-core release
# local: use your local ../productive-k3s-core checkout
PRODUCTIVE_K3S_SOURCE=remote
PRODUCTIVE_K3S_VERSION=0.9.4
PRODUCTIVE_K3S_RELEASE_REPO=jemacchi/productive-k3s-core
