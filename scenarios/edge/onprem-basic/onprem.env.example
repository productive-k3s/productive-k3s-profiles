# Copy this file to `onprem.env` and adjust the values for your environment.

# Required: primary machine that will become the K3S server.
ONPREM_SERVER_IP=192.168.1.10

# Optional: one or more agent IPs separated by spaces.
# Leave empty for a single-node path.
ONPREM_AGENT_IPS=192.168.1.11 192.168.1.12

# SSH access used by the local control machine.
ONPREM_SSH_USER=ubuntu
ONPREM_SSH_PORT=22
# ONPREM_SSH_KEY_PATH=$HOME/.ssh/id_ed25519
# ONPREM_SSH_EXTRA_OPTS="-o ProxyJump=bastion"

# Optional cluster naming and hostnames.
ONPREM_CLUSTER_NAME=productive-k3s-onprem
ONPREM_BASE_DOMAIN=k3s.lab.internal
ONPREM_RANCHER_HOST=rancher.k3s.lab.internal
ONPREM_REGISTRY_HOST=registry.k3s.lab.internal

# Optional remote work directory. If empty, the scenario derives it from $HOME on the server.
# ONPREM_REMOTE_DIR=

# Productive K3S Core source.
# The repository default is remote and pinned through scripts/release-config.sh.
# Uncomment the local mode only when you explicitly want to package a local checkout.
# PRODUCTIVE_K3S_SOURCE=local
# PRODUCTIVE_K3S_SOURCE=remote
# PRODUCTIVE_K3S_VERSION=0.9.4
# PRODUCTIVE_K3S_RELEASE_REPO=productive-k3s/productive-k3s-core
